<idea-plugin>
    <id>com.bingo.annotationtidy</id>
    <name>Annotation Tidy</name>
    <vendor email="dev@example.com">Bingo</vendor>

    <description><![CDATA[
        <p>Quickly tidy Java annotations on classes, methods, and fields.</p>
        <ul>
            <li>Trigger with a shortcut inside IntelliJ IDEA</li>
            <li>Sort annotations from shortest to longest</li>
            <li>Split stacked annotations into standalone lines</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
                id="Annotation Tidy"
                displayType="BALLOON"
                isLogByDefault="false"/>
    </extensions>

    <actions>
        <action
                id="AnnotationTidy.TidyJavaAnnotationsAction"
                class="com.bingo.annotationtidy.TidyJavaAnnotationsAction"
                text="Tidy Java Annotations"
                description="Reorder and normalize Java annotations in the current file">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift A"/>
        </action>
    </actions>
</idea-plugin>
